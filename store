        try{
            var S=Java.use("java.lang.System");
            S.exit.implementation=function(c){
                console.log("[Java] System.exit("+c+") BLOCKED");
            };
        }catch(e){}
    });
}

function scanRangesForZwf(){
    var found=false;
    Process.enumerateRanges({protection:'r-x',coalesce:true}).forEach(function(r){
        if(!r.file) return;
        var p=r.file.path||"";
        if(p.toLowerCase().indexOf("zwf")!==-1||p.toLowerCase().indexOf("liapp")!==-1){
            console.log("[SCAN] "+p+" @ "+r.base);
            hookZwf(r.base);
            found=true;
        }
    });
    return found;
}

function hookRegisterNatives(){
    try{
        var env=Java.vm.getEnv();
        var vtable=Memory.readPointer(env.handle);
        var regNativesPtr=Memory.readPointer(vtable.add(215*8));
        console.log("[RN] RegisterNatives @ "+regNativesPtr);
        Interceptor.attach(regNativesPtr,{onEnter:function(args){
            var count=args[3].toInt32();
            for(var i=0;i<count;i++){
                try{
                    var entry=args[2].add(i*24);
                    var nm=Memory.readCString(Memory.readPointer(entry));
                    var fnPtr=Memory.readPointer(entry.add(16));
                    var mod=Process.findModuleByAddress(fnPtr);
                    console.log("[RN] "+nm+" fnPtr="+fnPtr+" mod="+(mod?mod.name+" base="+mod.base:"ANON"));
                    if(mod){
                        if(mod.name.indexOf("zwf")!==-1||mod.name.indexOf("liapp")!==-1||mod.name.indexOf("guard")!==-1)
                            hookZwf(mod.base);
                    } else {
                        var scan=fnPtr.and(ptr("0xFFFFF000"));
                        for(var off=0;off<0x800000;off+=0x1000){
                            try{
                                var b=Memory.readByteArray(scan.sub(off),4);
                                var a=new Uint8Array(b);
                                if(a[0]===0x7F&&a[1]===0x45&&a[2]===0x4C&&a[3]===0x46){
                                    hookZwf(scan.sub(off));
                                    break;
                                }
                            }catch(e){break;}
                        }
                    }
                }catch(e){}
            }
        }});
    }catch(e){console.log("[RN] hook fail: "+e.message);}
}

