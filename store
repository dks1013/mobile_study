'use strict';

// ── 1. 프로세스 생존 ──
["exit","_exit","abort"].forEach(function(n){
    var f=Module.findExportByName("libc.so",n);
    if(f) Interceptor.replace(f,new NativeCallback(function(){},'void',['int']));
});
["kill","tgkill","tkill","pthread_kill"].forEach(function(n){
    var f=Module.findExportByName("libc.so",n);
    if(!f) return;
    Interceptor.attach(f,{onEnter:function(a){
        var i=(n==="kill"||n==="pthread_kill")?1:2;
        var s=a[i].toInt32();
        if(s===9||s===6||s===19) a[i]=ptr(0);
    }});
});
(function(){
    var f=Module.findExportByName("libc.so","raise");
    if(f) Interceptor.replace(f,new NativeCallback(function(){return 0;},'int',['int']));
    var sc=Module.findExportByName("libc.so","syscall");
    if(sc) Interceptor.attach(sc,{onEnter:function(a){
        var n=a[0].toInt32();
        if(n===93||n===94){a[0]=ptr(35);return;}
        if(n===129||n===130||n===131){var s=a[2].toInt32();if(s===9||s===6)a[2]=ptr(0);}
    }});
    var fk=Module.findExportByName("libc.so","fork");
    if(fk) Interceptor.replace(fk,new NativeCallback(function(){return -1;},'int',[]));
})();
console.log("[*] survive OK");

// ── 2. /proc 은닉 ──
(function(){
    var HIDE=["frida","gum-js","gmain","gdbus","linjector"];
    var f=Module.findExportByName("libc.so","fgets");
    if(!f) return;
    Interceptor.attach(f,{
        onEnter:function(a){this.buf=a[0];},
        onLeave:function(r){
            if(r.isNull()) return;
            try{
                var line=Memory.readUtf8String(this.buf);
                if(!line) return;
                var lo=line.toLowerCase();
                if(HIDE.some(function(s){return lo.indexOf(s)!==-1;}))
                    Memory.writeUtf8String(this.buf,"\n");
                else if(lo.indexOf("tracerpid:")===0&&lo.indexOf("tracerpid:\t0")===-1)
                    Memory.writeUtf8String(this.buf,"TracerPid:\t0\n");
            }catch(e){}
        }
    });
    var dip=Module.findExportByName("libc.so","dl_iterate_phdr");
    if(!dip) return;
    var _cbs=[];
    Interceptor.attach(dip,{onEnter:function(args){
        var orig=args[0];
        if(orig.isNull()) return;
        var origFn=new NativeFunction(orig,'int',['pointer','uint64','pointer']);
        var w=new NativeCallback(function(info,sz,data){
            try{
                var np=Memory.readPointer(info.add(8));
                if(!np.isNull()){
                    var nm=Memory.readCString(np).toLowerCase();
                    if(["frida","gadget","gum-js","linjector"].some(function(s){return nm.indexOf(s)!==-1;})) return 0;
                }
            }catch(e){}
            return origFn(info,sz,data);
        },'int',['pointer','uint64','pointer']);
        _cbs.push(w); args[0]=w;
    }});
})();
