var _zwfDone=false;
function hookZwf(base){
    if(_zwfDone) return;
    _zwfDone=true;
    console.log("[ZWF] base="+base);

    try{
        Interceptor.replace(base.add(0x7DFD0),
            new NativeCallback(function(code,param,msg){
                console.log("[ZWF] byte_7DFD0 BLOCKED event="+code+" param="+param);
            },'void',['int','int','pointer']));
        console.log("[ZWF] byte_7DFD0 REPLACE OK");
    }catch(e){console.log("[ZWF] byte_7DFD0 FAIL: "+e.message);}

    try{
        const libcKill=new NativeFunction(
            Module.findExportByName("libc.so","kill"),'int',['int','int']);
        Interceptor.replace(base.add(0x380C0),
            new NativeCallback(function(pid,sig){
                if(sig===9||sig===6||sig===19){
                    console.log("[ZWF] sub_380C0("+pid+","+sig+") KILL BLOCKED");
                    return 0;
                }
                return libcKill(pid,sig);
            },'int',['int','int']));
        console.log("[ZWF] sub_380C0 OK");
    }catch(e){console.log("[ZWF] sub_380C0 FAIL: "+e.message);}

    try{
        const mprotectFn=new NativeFunction(
            Module.findExportByName("libc.so","mprotect"),'int',['pointer','size_t','int']);
        Interceptor.replace(base.add(0xF9B0),
            new NativeCallback(function(dst,src,size){
                try{
                    const PAGE=4096;
                    const pageBase=src.and(ptr("0xFFFFFFFFFFFFF000"));
                    mprotectFn(pageBase,PAGE,5);
                    const bytes=Memory.readByteArray(src,size);
                    if(bytes&&!dst.isNull())
                        Memory.writeByteArray(dst,new Uint8Array(bytes));
                    return src;
                }catch(e2){
                    console.log("[ZWF] sub_F9B0: bad read @ "+src+" ("+e2.message+")");
                    return 0;
                }
            },'int64',['pointer','int64','int']));
        console.log("[ZWF] sub_F9B0 OK");
    }catch(e){console.log("[ZWF] sub_F9B0 FAIL: "+e.message);}

    Java.perform(function(){
        try{
            var P=Java.use("android.os.Process");
            P.killProcess.implementation=function(pid){
                console.log("[Java] Process.killProcess("+pid+") BLOCKED");
            };
